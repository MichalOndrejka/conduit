@page "{id}"
@model Conduit.McpServer.Pages.Sources.DeleteModel
@{
    ViewData["Title"] = "Delete Source";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Sources</a></li>
        <li class="breadcrumb-item active">Delete</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger shadow-sm">
            <div class="card-body text-center py-4">
                <h4 class="card-title mb-1">Delete source?</h4>
                <p class="text-muted mb-3">
                    <strong>@Model.Source.Name</strong>
                    <span class="badge bg-secondary ms-1">@Model.Source.Type</span>
                </p>
                <p class="text-muted small">
                    This removes the source configuration. Indexed documents in Qdrant are not automatically deleted.
                </p>

                <form method="post" class="d-flex justify-content-center gap-2 mt-3">
                    <button type="submit" class="btn btn-danger">Delete</button>
                    <a asp-page="/Index" class="btn btn-outline-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
