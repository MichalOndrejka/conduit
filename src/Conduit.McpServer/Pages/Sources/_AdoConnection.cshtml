@using Conduit.Rag.Models
@model Dictionary<string, string>
@* Shared ADO connection section (Base URL + Auth Type + credentials).
   Usage: <partial name="_AdoConnection" model="Model.Source.Config" /> *@

@{
    string Cfg(string key, string def = "") => Model.GetValueOrDefault(key, def) ?? def;

    var rawAuthType     = Cfg(ConfigKeys.AuthType);
    var currentAuthType = rawAuthType.Length > 0 ? rawAuthType
        : Cfg(ConfigKeys.Pat).Length > 0 ? "pat"
        : "none";

    string Show(params string[] types) => types.Contains(currentAuthType) ? string.Empty : "none";
}

<!-- Base URL -->
<div class="mb-3">
    <label class="form-label fw-medium">Base URL <span class="text-danger">*</span></label>
    <input name="ConfigBaseUrl" value="@Cfg(ConfigKeys.BaseUrl)"
           class="form-control" placeholder="https://dev.azure.com/myorg/MyProject" />
    <div class="form-text">
        Cloud: <code>https://dev.azure.com/org/project</code> &nbsp;·&nbsp;
        On-premise: <code>https://ado.company.com/Collection/Project</code>
    </div>
</div>

<!-- Auth Type -->
@{
    var authOptions = new (string Value, string Label)[]
    {
        ("pat",       "PAT (Personal Access Token)"),
        ("bearer",    "Bearer / OAuth Token"),
        ("ntlm",      "NTLM (Windows Auth)"),
        ("negotiate", "Negotiate (Kerberos)"),
        ("apikey",    "API Key (Custom Header)"),
        ("none",      "None / Anonymous"),
    };
}
<div class="mb-0">
    <label class="form-label fw-medium">Authentication</label>
    <select id="authTypeSelect" name="ConfigAuthType" class="form-select" onchange="updateAuthFields()" style="max-width:320px">
        @foreach (var opt in authOptions)
        {
            @Html.Raw($"<option value=\"{opt.Value}\"{(currentAuthType == opt.Value ? " selected" : "")}>{opt.Label}</option>")
        }
    </select>
</div>

<!-- PAT -->
<div id="auth-pat" class="mt-3" style="display:@Show("pat")">
    <label class="form-label fw-medium">Personal Access Token</label>
    <input name="ConfigPat" type="password" value="@Cfg(ConfigKeys.Pat)"
           class="form-control" style="max-width:480px" placeholder="••••••••" />
</div>

<!-- Bearer Token -->
<div id="auth-bearer" class="mt-3" style="display:@Show("bearer")">
    <label class="form-label fw-medium">Token</label>
    <input name="ConfigToken" type="password" value="@Cfg(ConfigKeys.Token)"
           class="form-control" style="max-width:480px" placeholder="••••••••" />
</div>

<!-- NTLM / Negotiate -->
<div id="auth-windows" class="mt-3" style="display:@Show("ntlm", "negotiate")">
    <p class="text-muted small mb-2">Leave all fields blank to authenticate as the current process identity (recommended for AD service accounts).</p>
    <div class="row g-2">
        <div class="col-md-4">
            <label class="form-label fw-medium">Username <small class="text-muted">(optional)</small></label>
            <input name="ConfigUsername" value="@Cfg(ConfigKeys.Username)"
                   class="form-control" placeholder="CORP\svc_account" />
        </div>
        <div class="col-md-4">
            <label class="form-label fw-medium">Password <small class="text-muted">(optional)</small></label>
            <input name="ConfigPassword" type="password" value="@Cfg(ConfigKeys.Password)"
                   class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label fw-medium">Domain <small class="text-muted">(optional)</small></label>
            <input name="ConfigDomain" value="@Cfg(ConfigKeys.Domain)"
                   class="form-control" placeholder="CORP" />
        </div>
    </div>
</div>

<!-- API Key -->
<div id="auth-apikey" class="mt-3" style="display:@Show("apikey")">
    <div class="row g-2">
        <div class="col-md-4">
            <label class="form-label fw-medium">Header Name <span class="text-danger">*</span></label>
            <input name="ConfigApiKeyHeader" value="@Cfg(ConfigKeys.ApiKeyHeader)"
                   class="form-control" placeholder="X-Api-Key" />
        </div>
        <div class="col-md-8">
            <label class="form-label fw-medium">Header Value <span class="text-danger">*</span></label>
            <input name="ConfigApiKeyValue" type="password" value="@Cfg(ConfigKeys.ApiKeyValue)"
                   class="form-control" />
        </div>
    </div>
</div>

<script>
function updateAuthFields() {
    var t = document.getElementById('authTypeSelect').value;
    document.getElementById('auth-pat').style.display     = (t === 'pat')                          ? '' : 'none';
    document.getElementById('auth-bearer').style.display  = (t === 'bearer')                       ? '' : 'none';
    document.getElementById('auth-windows').style.display = (t === 'ntlm' || t === 'negotiate')    ? '' : 'none';
    document.getElementById('auth-apikey').style.display  = (t === 'apikey')                       ? '' : 'none';
}
</script>
