@page
@model Conduit.McpServer.Pages.Sources.CreateModel
@using Conduit.Rag.Models
@{
    ViewData["Title"] = "Add Source";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Sources</a></li>
        <li class="breadcrumb-item active">Add Source</li>
    </ol>
</nav>

@if (string.IsNullOrEmpty(Model.SelectedType))
{
    <!-- Step 1: Pick a source type -->
    <h2 class="h4 mb-4">Choose a source type</h2>
    <div class="row g-3">
        @foreach (var (type, label, description) in Model.SourceTypes)
        {
            <div class="col-md-4">
                <a asp-page="/Sources/Create" asp-route-type="@type" class="text-decoration-none">
                    <div class="card h-100 source-type-card">
                        <div class="card-body">
                            <h5 class="card-title">@label</h5>
                            <p class="card-text text-muted small">@description</p>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}
else
{
    <!-- Step 2: Fill in config for chosen type -->
    <h2 class="h4 mb-4">Configure: @Model.TypeLabel</h2>

    <div class="card shadow-sm">
        <div class="card-body">
            <form method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Source.Type" />
                <input type="hidden" asp-for="Source.Id" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <!-- Name -->
                <div class="mb-3">
                    <label asp-for="Source.Name" class="form-label fw-medium">Name <span class="text-danger">*</span></label>
                    <input asp-for="Source.Name" class="form-control" placeholder="e.g. Sprint Backlog" />
                    <span asp-validation-for="Source.Name" class="text-danger small"></span>
                </div>

                <hr />

                <!-- Document -->
                @if (Model.SelectedType == SourceTypes.ManualDocument)
                {
                    <div class="mb-3">
                        <label class="form-label fw-medium">Upload file <small class="text-muted">(txt, md, pdf)</small></label>
                        <input type="file" name="ConfigFile" accept=".txt,.md,.pdf" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Or paste text</label>
                        <textarea name="ConfigContent" rows="12" class="form-control font-monospace"
                                  placeholder="Paste your document content here...">@Model.GetConfig(ConfigKeys.Content)</textarea>
                        <div class="form-text">If a file is uploaded it takes precedence over pasted text.</div>
                    </div>
                }

                <!-- ADO Connection (standard ADO source types; wiki and http-page handle their own connection UI) -->
                @if (Model.SelectedType != SourceTypes.ManualDocument
                  && Model.SelectedType != SourceTypes.AdoWiki
                  && Model.SelectedType != SourceTypes.HttpPage)
                {
                    <partial name="_AdoConnection" model="Model.Source.Config" />
                    <hr class="mt-4" />
                }

                <!-- ADO WIQL query types -->
                @if (Model.SelectedType == SourceTypes.AdoWorkItemQuery
                  || Model.SelectedType == SourceTypes.AdoRequirements
                  || Model.SelectedType == SourceTypes.AdoTestCase)
                {
                    <div class="mb-3 mt-3">
                        <label class="form-label fw-medium">WIQL Query <span class="text-danger">*</span></label>
                        <textarea name="ConfigQuery" rows="4" class="form-control font-monospace"
                                  placeholder="SELECT [System.Id] FROM WorkItems WHERE ...">@Model.GetConfig(ConfigKeys.Query)</textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Fields <small class="text-muted">(comma-separated, leave blank to fetch all)</small></label>
                        <input name="ConfigFields" value="@Model.GetConfig(ConfigKeys.Fields)" class="form-control font-monospace"
                               placeholder="System.Title,System.Description,System.State" />
                    </div>
                }

                <!-- ADO Code Repo -->
                @if (Model.SelectedType == SourceTypes.AdoCodeRepo)
                {
                    <div class="row g-3 mb-3 mt-3">
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Repository <span class="text-danger">*</span></label>
                            <input name="ConfigRepository" value="@Model.GetConfig(ConfigKeys.Repository)"
                                   class="form-control" placeholder="MyRepo" />
                            <div class="form-text">The repository name as it appears in ADO (not the full URL).</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Branch</label>
                            <input name="ConfigBranch" value="@Model.GetConfig(ConfigKeys.Branch, "main")"
                                   class="form-control" placeholder="main" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Glob Patterns <small class="text-muted">(comma-separated)</small></label>
                        <input name="ConfigGlobPatterns" value="@Model.GetConfig(ConfigKeys.GlobPatterns, "**/*.cs")"
                               class="form-control font-monospace" placeholder="**/*.cs,**/*.md" />
                        <div class="form-text">
                            Controls which files are fetched. Supports <code>**</code> (any depth) and <code>*</code> (any name within a segment).
                            Example: <code>**/*.cs,**/*.ts,**/README.md</code>
                        </div>
                    </div>
                }

                <!-- ADO Pipeline Build -->
                @if (Model.SelectedType == SourceTypes.AdoPipelineBuild)
                {
                    <div class="row g-3 mb-3 mt-3">
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Pipeline ID <span class="text-danger">*</span></label>
                            <input name="ConfigPipelineId" value="@Model.GetConfig(ConfigKeys.PipelineId)"
                                   class="form-control" type="number" placeholder="42" />
                            <div class="form-text">The numeric definition ID — visible in the pipeline URL: <code>.../_build?definitionId=42</code></div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Number of Recent Builds</label>
                            <input name="ConfigLastNBuilds" value="@Model.GetConfig(ConfigKeys.LastNBuilds, "5")"
                                   class="form-control" type="number" min="1" max="50" />
                            <div class="form-text">How many of the most recent builds to index (default 5, max 50).</div>
                        </div>
                    </div>
                }

                <!-- ADO Wiki -->
                @if (Model.SelectedType == SourceTypes.AdoWiki)
                {
                    <partial name="_AdoConnection" model="Model.Source.Config" />
                    <hr class="mt-4" />
                    <div class="row g-3 mb-3 mt-3">
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Wiki Name <small class="text-muted">(optional — defaults to first wiki)</small></label>
                            <input name="ConfigWikiName" value="@Model.GetConfig(ConfigKeys.WikiName)"
                                   class="form-control" placeholder="MyProject.wiki" />
                            <div class="form-text">Leave blank to use the first wiki in the project. The name is visible in the ADO wiki URL.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Path Filter <small class="text-muted">(optional prefix)</small></label>
                            <input name="ConfigPathFilter" value="@Model.GetConfig(ConfigKeys.PathFilter)"
                                   class="form-control" placeholder="/Architecture" />
                            <div class="form-text">Only index pages under this path. Leave blank to index the entire wiki.</div>
                        </div>
                    </div>
                }

                <!-- HTTP Page -->
                @if (Model.SelectedType == SourceTypes.HttpPage)
                {
                    var httpCurrentCt   = Model.GetConfig(ConfigKeys.ContentType, "auto");
                    var httpCtOpts      = new[] { ("auto","Auto-detect"), ("html","HTML"), ("json","JSON"), ("text","Plain text") };
                    var httpAuthType    = Model.GetConfig(ConfigKeys.AuthType, "none");
                    var httpAuthOpts    = new[] { ("none","None / Anonymous"), ("pat","Personal Access Token (Basic)"), ("bearer","Bearer Token"), ("apikey","API Key Header") };
                    <div class="mb-3">
                        <label class="form-label fw-medium">URL <span class="text-danger">*</span></label>
                        <input name="ConfigUrl" value="@Model.GetConfig(ConfigKeys.Url)"
                               class="form-control" type="url" placeholder="https://example.com/page" />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Title <small class="text-muted">(optional — defaults to hostname)</small></label>
                            <input name="ConfigTitle" value="@Model.GetConfig(ConfigKeys.Title)"
                                   class="form-control" placeholder="My Documentation Page" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">Content Type</label>
                            <select name="ConfigContentType" class="form-select">
                                @foreach (var opt in httpCtOpts)
                                {
                                    @Html.Raw($"<option value=\"{opt.Item1}\"{(httpCurrentCt == opt.Item1 ? " selected" : "")}>{opt.Item2}</option>")
                                }
                            </select>
                        </div>
                    </div>
                    <hr />
                    <h6 class="text-muted mb-3">Authentication</h6>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Auth Type</label>
                        <select name="ConfigAuthType" id="httpAuthType" class="form-select" onchange="updateHttpAuthFields()">
                            @foreach (var opt in httpAuthOpts)
                            {
                                @Html.Raw($"<option value=\"{opt.Item1}\"{(httpAuthType == opt.Item1 ? " selected" : "")}>{opt.Item2}</option>")
                            }
                        </select>
                    </div>
                    <div id="http-auth-pat" class="mb-3" style="display:@(httpAuthType == "pat" ? "block" : "none")">
                        <label class="form-label fw-medium">Personal Access Token</label>
                        <input name="ConfigPat" value="@Model.GetConfig(ConfigKeys.Pat)"
                               class="form-control font-monospace" type="password" />
                    </div>
                    <div id="http-auth-bearer" class="mb-3" style="display:@(httpAuthType == "bearer" ? "block" : "none")">
                        <label class="form-label fw-medium">Bearer Token</label>
                        <input name="ConfigToken" value="@Model.GetConfig(ConfigKeys.Token)"
                               class="form-control font-monospace" type="password" />
                    </div>
                    <div id="http-auth-apikey" style="display:@(httpAuthType == "apikey" ? "block" : "none")">
                        <div class="row g-3 mb-3">
                            <div class="col-md-5">
                                <label class="form-label fw-medium">Header Name</label>
                                <input name="ConfigApiKeyHeader" value="@Model.GetConfig(ConfigKeys.ApiKeyHeader)"
                                       class="form-control" placeholder="X-Api-Key" />
                            </div>
                            <div class="col-md-7">
                                <label class="form-label fw-medium">Header Value</label>
                                <input name="ConfigApiKeyValue" value="@Model.GetConfig(ConfigKeys.ApiKeyValue)"
                                       class="form-control font-monospace" type="password" />
                            </div>
                        </div>
                    </div>
                    <script>
                        function updateHttpAuthFields() {
                            var t = document.getElementById('httpAuthType').value;
                            document.getElementById('http-auth-pat').style.display    = (t === 'pat')    ? 'block' : 'none';
                            document.getElementById('http-auth-bearer').style.display = (t === 'bearer') ? 'block' : 'none';
                            document.getElementById('http-auth-apikey').style.display = (t === 'apikey') ? 'block' : 'none';
                        }
                    </script>
                }

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">Save Source</button>
                    <a asp-page="/Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
}
