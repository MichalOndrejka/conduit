@page "{id}"
@model Conduit.McpServer.Pages.Sources.EditModel
@using Conduit.Rag.Models
@{
    ViewData["Title"] = "Edit Source";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Sources</a></li>
        <li class="breadcrumb-item active">Edit — @Model.Source.Name</li>
    </ol>
</nav>

<h2 class="h4 mb-4">Edit: @Model.TypeLabel</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Source.Type" />
            <input type="hidden" asp-for="Source.Id" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <!-- Name -->
            <div class="mb-3">
                <label asp-for="Source.Name" class="form-label fw-medium">Name <span class="text-danger">*</span></label>
                <input asp-for="Source.Name" class="form-control" />
                <span asp-validation-for="Source.Name" class="text-danger small"></span>
            </div>

            <hr />

            <!-- Document -->
            @if (Model.Source.Type == SourceTypes.ManualDocument)
            {
                <div class="mb-3">
                    <label class="form-label fw-medium">Upload file <small class="text-muted">(txt, md, pdf)</small></label>
                    <input type="file" name="ConfigFile" accept=".txt,.md,.pdf" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-medium">Or paste text</label>
                    <textarea name="ConfigContent" rows="12" class="form-control font-monospace">@Model.GetConfig(ConfigKeys.Content)</textarea>
                </div>
            }

            <!-- ADO Connection -->
            @if (Model.Source.Type != SourceTypes.ManualDocument
              && Model.Source.Type != SourceTypes.AdoWiki
              && Model.Source.Type != SourceTypes.HttpPage)
            {
                <partial name="_AdoConnection" model="Model.Source.Config" />
                <hr class="mt-4" />
            }

            <!-- ADO WIQL query types -->
            @if (Model.Source.Type == SourceTypes.AdoWorkItemQuery
              || Model.Source.Type == SourceTypes.AdoRequirements
              || Model.Source.Type == SourceTypes.AdoTestCase)
            {
                <div class="mb-3 mt-3">
                    <label class="form-label fw-medium">WIQL Query <span class="text-danger">*</span></label>
                    <textarea name="ConfigQuery" rows="4" class="form-control font-monospace">@Model.GetConfig(ConfigKeys.Query)</textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-medium">Fields <small class="text-muted">(comma-separated, leave blank to fetch all)</small></label>
                    <input name="ConfigFields" value="@Model.GetConfig(ConfigKeys.Fields)" class="form-control font-monospace"
                           placeholder="System.Title,System.Description,System.State" />
                </div>
            }

            <!-- ADO Code Repo -->
            @if (Model.Source.Type == SourceTypes.AdoCodeRepo)
            {
                <div class="row g-3 mb-3 mt-3">
                    <div class="col-md-6">
                        <label class="form-label fw-medium">Repository <span class="text-danger">*</span></label>
                        <input name="ConfigRepository" value="@Model.GetConfig(ConfigKeys.Repository)" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-medium">Branch</label>
                        <input name="ConfigBranch" value="@Model.GetConfig(ConfigKeys.Branch, "main")" class="form-control" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-medium">Glob Patterns <small class="text-muted">(comma-separated)</small></label>
                    <input name="ConfigGlobPatterns" value="@Model.GetConfig(ConfigKeys.GlobPatterns)" class="form-control font-monospace" />
                </div>
            }

            <!-- ADO Pipeline Build -->
            @if (Model.Source.Type == SourceTypes.AdoPipelineBuild)
            {
                <div class="row g-3 mb-3 mt-3">
                    <div class="col-md-6">
                        <label class="form-label fw-medium">Pipeline ID <span class="text-danger">*</span></label>
                        <input name="ConfigPipelineId" value="@Model.GetConfig(ConfigKeys.PipelineId)" class="form-control" type="number" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-medium">Number of Recent Builds</label>
                        <input name="ConfigLastNBuilds" value="@Model.GetConfig(ConfigKeys.LastNBuilds, "5")" class="form-control" type="number" />
                    </div>
                </div>
            }

            <!-- ADO Wiki -->
            @if (Model.Source.Type == SourceTypes.AdoWiki)
            {
                <partial name="_AdoConnection" model="Model.Source.Config" />
                <hr class="mt-4" />
                <div class="row g-3 mb-3 mt-3">
                    <div class="col-md-6">
                        <label class="form-label fw-medium">Wiki Name <small class="text-muted">(optional)</small></label>
                        <input name="ConfigWikiName" value="@Model.GetConfig(ConfigKeys.WikiName)" class="form-control" placeholder="MyProject.wiki" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-medium">Path Filter <small class="text-muted">(optional)</small></label>
                        <input name="ConfigPathFilter" value="@Model.GetConfig(ConfigKeys.PathFilter)" class="form-control" placeholder="/Architecture" />
                    </div>
                </div>
            }

            <!-- HTTP Page -->
            @if (Model.Source.Type == SourceTypes.HttpPage)
            {
                var httpCurrentCt  = Model.GetConfig(ConfigKeys.ContentType, "auto");
                var httpCtOpts     = new[] { ("auto","Auto-detect"), ("html","HTML"), ("json","JSON"), ("text","Plain text") };
                var httpAuthType   = Model.GetConfig(ConfigKeys.AuthType, "none");
                var httpAuthOpts   = new[] { ("none","None / Anonymous"), ("pat","Personal Access Token (Basic)"), ("bearer","Bearer Token"), ("apikey","API Key Header") };
                <div class="mb-3">
                    <label class="form-label fw-medium">URL <span class="text-danger">*</span></label>
                    <input name="ConfigUrl" value="@Model.GetConfig(ConfigKeys.Url)" class="form-control" type="url" />
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-medium">Title <small class="text-muted">(optional)</small></label>
                        <input name="ConfigTitle" value="@Model.GetConfig(ConfigKeys.Title)" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-medium">Content Type</label>
                        <select name="ConfigContentType" class="form-select">
                            @foreach (var opt in httpCtOpts)
                            {
                                @Html.Raw($"<option value=\"{opt.Item1}\"{(httpCurrentCt == opt.Item1 ? " selected" : "")}>{opt.Item2}</option>")
                            }
                        </select>
                    </div>
                </div>
                <hr />
                <h6 class="text-muted mb-3">Authentication</h6>
                <div class="mb-3">
                    <label class="form-label fw-medium">Auth Type</label>
                    <select name="ConfigAuthType" id="httpAuthType" class="form-select" onchange="updateHttpAuthFields()">
                        @foreach (var opt in httpAuthOpts)
                        {
                            @Html.Raw($"<option value=\"{opt.Item1}\"{(httpAuthType == opt.Item1 ? " selected" : "")}>{opt.Item2}</option>")
                        }
                    </select>
                </div>
                <div id="http-auth-pat" class="mb-3" style="display:@(httpAuthType == "pat" ? "block" : "none")">
                    <label class="form-label fw-medium">Personal Access Token</label>
                    <input name="ConfigPat" value="@Model.GetConfig(ConfigKeys.Pat)" class="form-control font-monospace" type="password" />
                </div>
                <div id="http-auth-bearer" class="mb-3" style="display:@(httpAuthType == "bearer" ? "block" : "none")">
                    <label class="form-label fw-medium">Bearer Token</label>
                    <input name="ConfigToken" value="@Model.GetConfig(ConfigKeys.Token)" class="form-control font-monospace" type="password" />
                </div>
                <div id="http-auth-apikey" style="display:@(httpAuthType == "apikey" ? "block" : "none")">
                    <div class="row g-3 mb-3">
                        <div class="col-md-5">
                            <label class="form-label fw-medium">Header Name</label>
                            <input name="ConfigApiKeyHeader" value="@Model.GetConfig(ConfigKeys.ApiKeyHeader)" class="form-control" placeholder="X-Api-Key" />
                        </div>
                        <div class="col-md-7">
                            <label class="form-label fw-medium">Header Value</label>
                            <input name="ConfigApiKeyValue" value="@Model.GetConfig(ConfigKeys.ApiKeyValue)" class="form-control font-monospace" type="password" />
                        </div>
                    </div>
                </div>
                <script>
                    function updateHttpAuthFields() {
                        var t = document.getElementById('httpAuthType').value;
                        document.getElementById('http-auth-pat').style.display    = (t === 'pat')    ? 'block' : 'none';
                        document.getElementById('http-auth-bearer').style.display = (t === 'bearer') ? 'block' : 'none';
                        document.getElementById('http-auth-apikey').style.display = (t === 'apikey') ? 'block' : 'none';
                    }
                </script>
            }

            <!-- Per-type hints above Save -->
            <p class="text-muted small mt-4 mb-2">
                @if (Model.Source.Type == SourceTypes.ManualDocument)
                {
                    <span>Uploaded file takes precedence over pasted text. Sync after saving to re-index.</span>
                }
                else if (Model.Source.Type == SourceTypes.AdoWorkItemQuery
                      || Model.Source.Type == SourceTypes.AdoRequirements
                      || Model.Source.Type == SourceTypes.AdoTestCase)
                {
                    <span>SELECT columns in the WIQL are ignored — all relevant fields are fetched automatically.</span>
                }
                else if (Model.Source.Type == SourceTypes.AdoCodeRepo)
                {
                    <span>Glob patterns match from the repo root — e.g. <code>**/*.cs,**/*.md</code>. Leave blank to index all text files.</span>
                }
                else if (Model.Source.Type == SourceTypes.AdoPipelineBuild)
                {
                    <span>Pipeline ID is the <code>definitionId</code> in the ADO pipeline URL. Only completed builds are indexed.</span>
                }
                else if (Model.Source.Type == SourceTypes.AdoWiki)
                {
                    <span>Leave Wiki Name blank to use the project's default wiki. Path Filter limits indexing to a subtree.</span>
                }
            </p>

            <div class="d-flex gap-2 mt-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-page="/Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
