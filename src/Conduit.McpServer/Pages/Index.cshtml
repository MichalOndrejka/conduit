@page
@model IndexModel
@{
    ViewData["Title"] = "Sources";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0">Sources</h1>
        <p class="text-muted mb-0">Configure the data sources that Conduit indexes for RAG search.</p>
    </div>
    <a asp-page="/Sources/Create" class="btn btn-primary">+ Add Source</a>
</div>

@if (!Model.Sources.Any())
{
    <div class="card border-0 bg-light text-center py-5">
        <div class="card-body">
            <p class="text-muted mb-3">No sources configured yet.</p>
            <a asp-page="/Sources/Create" class="btn btn-primary">Add your first source</a>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Sync</th>
                    <th>Last Synced</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var source in Model.Sources)
                {
                    <tr>
                        <td class="fw-medium">@source.Name</td>
                        <td><code class="text-secondary">@source.Type</code></td>
                        <td data-sync-status-cell="@source.Id">
                            @Html.Raw(SyncBadgeHtml(source.SyncStatus, source.SyncError))
                        </td>
                        <td data-sync-time-cell="@source.Id" class="text-muted">
                            @(source.LastSyncedAt.HasValue
                                ? source.LastSyncedAt.Value.ToString("yyyy-MM-dd HH:mm")
                                : "Never")
                        </td>
                        <td class="text-end">
                            <form method="post" asp-page-handler="Sync" asp-route-id="@source.Id" class="d-inline me-1">
                                <button type="submit" class="btn btn-sm btn-outline-primary"
                                        @(source.SyncStatus == "syncing" ? "disabled" : "")>Sync</button>
                            </form>
                            <a asp-page="/Sources/Edit" asp-route-id="@source.Id"
                               class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                            <a asp-page="/Sources/Delete" asp-route-id="@source.Id"
                               class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@functions {
    static string SyncBadgeHtml(string status, string? error) => status switch
    {
        "syncing"       => "<span class=\"badge bg-warning text-dark\"><span class=\"spinner-border spinner-border-sm me-1\" role=\"status\"></span>Syncing&hellip;</span>",
        "completed"     => "<span class=\"badge bg-success\">Synced</span>",
        "failed"        => FailedBadgeHtml(error),
        "needs-reindex" => "<span class=\"badge bg-warning text-dark\">Re-index needed</span>",
        _               => "<span class=\"badge bg-secondary\">Idle</span>"
    };

    static string FailedBadgeHtml(string? error)
    {
        var id  = $"err-{Guid.NewGuid():N}";
        var msg = System.Web.HttpUtility.HtmlEncode(error ?? string.Empty);
        return $"""
            <span class="badge bg-danger">Failed</span>
            {(string.IsNullOrEmpty(error) ? "" : $"""
            <br><a class="text-danger small" data-bs-toggle="collapse" href="#{id}" style="font-size:.75rem;text-decoration:none">Show error</a>
            <div class="collapse mt-1" id="{id}">
              <pre class="text-danger border border-danger rounded p-2 mb-0" style="font-size:.72rem;white-space:pre-wrap;word-break:break-word">{msg}</pre>
            </div>
            """)}
            """;
    }
}

@section Scripts {
<script>
    function syncBadge(status, error) {
        if (status === 'syncing')
            return '<span class="badge bg-warning text-dark"><span class="spinner-border spinner-border-sm me-1" role="status"></span>Syncing&hellip;</span>';
        if (status === 'completed')
            return '<span class="badge bg-success">Synced</span>';
        if (status === 'failed') {
            const id  = 'err-' + Math.random().toString(36).slice(2);
            const msg = (error ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
            const detail = msg ? `<br><a class="text-danger small" data-bs-toggle="collapse" href="#${id}" style="font-size:.75rem;text-decoration:none">Show error</a><div class="collapse mt-1" id="${id}"><pre class="text-danger border border-danger rounded p-2 mb-0" style="font-size:.72rem;white-space:pre-wrap;word-break:break-word">${msg}</pre></div>` : '';
            return `<span class="badge bg-danger">Failed</span>${detail}`;
        }
        if (status === 'needs-reindex')
            return '<span class="badge bg-warning text-dark">Re-index needed</span>';
        return '<span class="badge bg-secondary">Idle</span>';
    }

    function pollStatus() {
        fetch('?handler=Status')
            .then(r => r.json())
            .then(data => {
                let stillSyncing = false;
                data.forEach(s => {
                    const badge = document.querySelector(`[data-sync-status-cell="${s.id}"]`);
                    if (badge) badge.innerHTML = syncBadge(s.syncStatus, s.syncError);

                    const time = document.querySelector(`[data-sync-time-cell="${s.id}"]`);
                    if (time) time.textContent = s.lastSyncedAt ?? 'Never';

                    if (s.syncStatus === 'syncing') stillSyncing = true;
                });
                if (stillSyncing) setTimeout(pollStatus, 2000);
            })
            .catch(() => { /* swallow network errors */ });
    }

    // Start polling if any source is already in syncing state on page load
    if (@Json.Serialize(Model.Sources.Any(s => s.SyncStatus == "syncing"))) {
        setTimeout(pollStatus, 2000);
    }
</script>
}
