# Credentials (PAT, tokens, API keys) are now managed in the UI at /credentials.
# They are stored encrypted in the data directory — no env vars needed per source.

# Optional: provide a stable Fernet encryption key for credentials.
# If not set, a key is auto-generated in the data directory on first start.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CONDUIT_SECRET_KEY=

# Qdrant connection (useful in Docker; defaults: localhost:6333)
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# Data directory (defaults to current working directory)
# CONDUIT_DATA_DIR=/data
